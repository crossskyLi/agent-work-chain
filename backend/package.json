{
  "name": "@agent-work-chain/indexer",
  "version": "0.2.0",
  "description": "Audit Swarm indexer — indexes AuditRegistry events and serves audit data API",
  "main": "src/index.ts",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "start:prod": "pm2 start ecosystem.config.cjs --env production",
    "stop:prod": "pm2 stop ecosystem.config.cjs",
    "reload:prod": "pm2 reload ecosystem.config.cjs",
    "seed": "tsx scripts/seed-mock-data.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "ethers": "^6.13.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "redis": "^5.11.0",
    "siwe": "^2.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^24.5.2",
    "@types/pg": "^8.18.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^1.6.0"
  },
  "license": "MIT"
}
